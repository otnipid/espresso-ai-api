{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "generate-types": "ts-node src/scripts/generate-types.ts",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:coverage": "NODE_ENV=test jest --coverage",
    "test:unit": "NODE_ENV=test jest src/__tests__/unit",
    "test:unit:watch": "NODE_ENV=test jest --watch src/__tests__/unit",
    "test:unit:coverage": "NODE_ENV=test jest --coverage src/__tests__/unit",
    "test:integration": "NODE_ENV=test jest src/__tests__/integration",
    "test:integration:watch": "NODE_ENV=test jest --watch src/__tests__/integration",
    "test:integration:coverage": "NODE_ENV=test jest --coverage src/__tests__/integration",
    "db:start": "./scripts/start-test-db.sh",
    "db:stop": "docker-compose --profile test down",
    "db:logs": "docker-compose --profile test logs -f postgres",
    "test:docker": "docker-compose --profile local up --build --abort-on-container-exit",
    "test:docker:local": "docker-compose --profile local up --build",
    "docker:down": "docker-compose --profile local down",
    "docker:logs": "docker-compose --profile local logs -f api"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "pg": "^8.17.2",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@jest/globals": "^30.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
