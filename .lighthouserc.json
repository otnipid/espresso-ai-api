{
  "ci": {
    "collect": {
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories": ["performance", "accessibility", "best-practices", "seo"],
        "minScore": {
          "performance": 80,
          "accessibility": 90,
          "best-practices": 80,
          "seo": 80
        }
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
