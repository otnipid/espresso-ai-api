# Test Environment Configuration
NODE_ENV=test

# Project Configuration
COMPOSE_PROJECT_NAME=espresso_ml_test

# Database Configuration (matching api-integration.md standards)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=espresso_ml

# Optional database settings
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30
DB_STATEMENT_TIMEOUT=60

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# API Configuration
API_PORT=3001

# Docker Compose Settings
COMPOSE_PROFILES=test
