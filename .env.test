# Test Environment Configuration
NODE_ENV=test

# Kubernetes PostgreSQL Test Database Configuration (Primary)
TEST_DB_HOST=espresso-db-postgres.espresso-development.svc.cluster.local
TEST_DB_PORT=5432
TEST_DB_USERNAME=postgres_user
TEST_DB_PASSWORD=postgres_password
TEST_DB_DATABASE=espresso_ml_dev
TEST_DB_SSL=false

# Local PostgreSQL Test Database Configuration (Fallback)
# TEST_DB_HOST=localhost
# TEST_DB_PORT=5432
# TEST_DB_USERNAME=postgres
# TEST_DB_PASSWORD=password
# TEST_DB_DATABASE=espresso_ml_test

# For local development, you can override these in your local environment
# For CI/CD, the Kubernetes configuration will be used automatically
